{
    "version": 2,
    "builds": [
        {
            "src": "./index.js",
            "use": "@vercel/node"
        }
    ],
   
    "routes": [{ "source": "/(.*)", "destination": "index.js" }]
}

{
    "version": 2,
    "builds": [
        {
            "src": "src/index.js",
            "use": "@vercel/node",
            "config": { "includeFiles": ["dist/**"] }
        }
    ],
    "rewrites": [{ "source": "/(.*)", "destination": "src/index.js" }]
}