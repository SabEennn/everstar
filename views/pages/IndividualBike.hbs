<div class="h-[88vh] overflow-hidden">
  <div
    class="rounded-lg shadow md:flex-row flex-col dark:bg-gray-800 dark:border-gray-700 flex justify-center"
  >
    <div class="h-[88vh]">
      <img class="h-full w-full object-contain" src="{{bikedata.imageLinks.[0]}}" alt="" />
    </div>
    <div class="bg-slate-200 m-10 p-5 my-36 h-auto">
      <div href="#">
        <h5 class="mb-2 text-2xl font-bold tracking-tight text-gray-900 dark:text-white">
          {{ bikedata.name }}
        </h5>
      </div>
      <p class="mb-3 font-normal text-gray-700 dark:text-gray-400">Rs.{{ bikedata.price }}00</p>

      {{!--
      <div class="ColorOption flex gap-3">
        <span class="color1 rounded-full h-8 aspect-square bg-red-300"></span>
        <span class="color2 rounded-full h-8 aspect-square bg-red-300"></span>
        <span class="color3 rounded-full h-8 aspect-square bg-red-300"></span>
        <span class="color4 rounded-full h-8 aspect-square bg-red-300"></span>
      </div>
      --}}
      <!-- Existing content displaying other bike details -->

      <!-- Loop through imageLinks array and display image divs -->
      {{#each bikedata.imageLinks}}
      <div class="h-10 aspect-square rounded-full bg-black flex gap-5"></div>
      {{/each}}
    </div>
  </div>
</div>
